PORT=8080
NODE_ENV=development

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GCP_LOCATION=us-central1

# Gemini (use GOOGLE_API_KEY for AI Studio or Vertex with project above)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Firestore
FIRESTORE_COLLECTION_PATIENTS=patients
FIRESTORE_COLLECTION_SESSIONS=intake_sessions

# BigQuery
BIGQUERY_DATASET=healthcare_analytics
BIGQUERY_TABLE=intake_events

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=healthcare-clinical-context
PINECONE_NAMESPACE=clinical-guidelines

# Demo mode (no GCP credentials — uses local mocks)
DEMO_MODE=true

# CORS
FRONTEND_URL=http://localhost:5173
